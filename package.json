{
	"name": "n8n-nodes-brightpearl",
	"version": "0.19.1",
	"description": "n8n community node for the Brightpearl API (orders, products, price lists)",
	"keywords": [
		"n8n-community-node-package"
	],
	"license": "MIT",
	"author": {
		"name": "Zewb"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Zewb/n8n-node-brightpearl.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"prepublishOnly": "npm run build && npm run lint"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": false,
		"credentials": [
			"dist/credentials/BrightpearlApi.credentials.js",
			"dist/credentials/BrightpearlOAuth2Api.credentials.js"
		],
		"nodes": [
			"dist/nodes/Brightpearl/Brightpearl.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.29.0",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
